{
    "name": "arseno25/filament-privacy-blur",
    "description": "Visual privacy layer for Filament — blur and mask sensitive data in tables, forms, and infolists",
    "keywords": [
        "laravel",
        "filament",
        "filament-plugin",
        "privacy",
        "data-masking",
        "blur",
        "gdpr",
        "sensitive-data",
        "filament-privacy-blur"
    ],
    "homepage": "https://github.com/arseno25/filament-privacy-blur",
    "support": {
        "issues": "https://github.com/arseno25/filament-privacy-blur/issues",
        "source": "https://github.com/arseno25/filament-privacy-blur"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Arseno25",
            "homepage": "https://github.com/arseno25",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "Arseno25\\FilamentPrivacyBlur\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arseno25\\FilamentPrivacyBlur\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arseno25\\FilamentPrivacyBlur\\FilamentPrivacyBlurServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "audit": {
            "abandoned": "report",
            "ignore": {
                "PKSA-5jz8-6tcw-pbk4": "phpunit 11.5 advisory — only reachable in test runners, no production impact. Upstream fix requires phpunit 12, which needs PHP 8.3+.",
                "PKSA-z3gr-8qht-p93v": "phpunit 11.5 advisory — only reachable in test runners, no production impact. Upstream fix requires phpunit 12, which needs PHP 8.3+."
            }
        }
    },
    "prefer-stable": true
}
