includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 4
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    checkOctaneCompatibility: true
    checkModelProperties: true

    ignoreErrors:
        -
            message: '#(Undefined variable: \$this|Variable \$this in PHPDoc tag \@var does not exist)#'
            path: src/Filament/ColumnPrivacyMacros.php

